<Window x:Class="PCDoctor.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="PCDoctor"
        Height="850"
        Width="1150"
        MinHeight="800"
        MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        Background="#0B1020">

    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#151B2E"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="10"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A9B7D8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#D7DEF5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="10"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="PCDoctor"
                       FontSize="36"
                       FontWeight="Bold"/>

            <TextBlock Text="System Monitoring &amp; Diagnostics"
                       FontSize="15"
                       Foreground="#8F9BB8"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="180"/>
                <RowDefinition Height="240"/>
                <RowDefinition Height="210"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="CPU Usage" Style="{StaticResource SectionTitleStyle}"/>

                    <TextBlock x:Name="CpuUsageText"
                               Text="0%"
                               FontSize="44"
                               FontWeight="Bold"
                               Margin="0,16,0,18"/>

                    <ProgressBar x:Name="CpuProgressBar"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Memory Usage" Style="{StaticResource SectionTitleStyle}"/>

                    <TextBlock x:Name="MemoryUsageText"
                               Text="0 GB / 0 GB"
                               FontSize="28"
                               FontWeight="Bold"
                               Margin="0,22,0,20"/>

                    <ProgressBar x:Name="MemoryProgressBar"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Top Processes" Style="{StaticResource SectionTitleStyle}"/>

                    <ListBox x:Name="ProcessListBox"
                             MaxHeight="115"
                             Margin="0,14,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Disk Usage" Style="{StaticResource SectionTitleStyle}"/>

                    <ListBox x:Name="DiskListBox"
                             MaxHeight="165"
                             Margin="0,14,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="History" Style="{StaticResource SectionTitleStyle}"/>

                    <ListBox x:Name="HistoryListBox"
                             MaxHeight="165"
                             Margin="0,14,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="CPU History" Style="{StaticResource SectionTitleStyle}"/>

                    <lvc:CartesianChart x:Name="CpuChart"
                                        Grid.Row="1"
                                        Series="{Binding CpuSeries}"
                                        Height="140"
                                        Margin="0,12,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>