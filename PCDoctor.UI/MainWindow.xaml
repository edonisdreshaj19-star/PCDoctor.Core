<Window x:Class="PCDoctor.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PCDoctor.UI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        
             <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="PCDoctor Dashboard"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="White"/>

        <!-- Dashboard -->
        <UniformGrid Grid.Row="2"
                     Columns="2"
                     Rows="2"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Top">

            <!-- CPU -->
            <Border Background="#1B1F2A"
                    CornerRadius="12"
                    Margin="10"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="CPU"
                               FontSize="16"
                               Foreground="#AAAAAA"/>

                    <TextBlock x:Name="CpuUsageText"
                               Text="0%"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,10,0,10"/>

                    <ProgressBar x:Name="CpuProgressBar"
                                 Minimum="0"
                                 Maximum="100"
                                 Height="12"/>

                </StackPanel>

            </Border>

            <!-- RAM -->
            <Border Background="#1B1F2A"
                    CornerRadius="12"
                    Margin="10"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="Memory"
                               FontSize="16"
                               Foreground="#AAAAAA"/>

                    <TextBlock x:Name="MemoryUsageText"
                               Text="0 MB / 0 MB"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,10,0,10"/>

                    <ProgressBar x:Name="MemoryProgressBar"
                                 Minimum="0"
                                 Maximum="100"
                                 Height="12"/>

                </StackPanel>

            </Border>

            <!-- Disk -->
            <Border Background="#1B1F2A"
                    CornerRadius="12"
                    Margin="10"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="Disk"
                               FontSize="16"
                               Foreground="#AAAAAA"/>

                    <ListBox x:Name="DiskListBox"
                               Background="Transparent"
                               BorderThickness="0"
                               Foreground="White"
                               Margin="0,10,0,0"/>

                </StackPanel>

            </Border>

            <!-- Processes -->
            <Border Background="#1B1F2A"
                    CornerRadius="12"
                    Margin="10"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="Top Processes"
                               FontSize="16"
                               Foreground="#AAAAAA"/>

                    <ListBox x:Name="ProcessListBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             Margin="0,10,0,0"/>

                </StackPanel>

            </Border>

        </UniformGrid>
    </Grid>
</Window>
