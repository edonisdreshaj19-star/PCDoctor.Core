<UserControl x:Class="PCDoctor.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="#0B1020"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="320"/>
                <RowDefinition Height="230"/>
            </Grid.RowDefinitions>

            <UniformGrid Grid.Row="0"
                         Columns="4">

                <Border Style="{StaticResource SmallCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="CPU Usage"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock Grid.Row="1"
                                   Text="{Binding Dashboard.CpuUsageText}"
                                   Style="{StaticResource MetricValueStyle}"
                                   VerticalAlignment="Center"/>

                        <ProgressBar Grid.Row="2"
                                     Value="{Binding Dashboard.CpuProgressValue}"
                                     Foreground="{Binding Dashboard.CpuProgressBrush}"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SmallCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Memory Usage"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock Grid.Row="1"
                                   Text="{Binding Dashboard.MemoryUsageText}"
                                   FontSize="25"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,16,0,16"
                                   VerticalAlignment="Center"/>

                        <ProgressBar Grid.Row="2"
                                     Value="{Binding Dashboard.MemoryProgressValue}"
                                     Foreground="{Binding Dashboard.MemoryProgressBrush}"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SmallCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="System Health"
                                       Style="{StaticResource SectionTitleStyle}"
                                       VerticalAlignment="Center"/>

                            <Border Grid.Column="1"
                                    Background="#222B45"
                                    CornerRadius="10"
                                    Padding="10,5"
                                    MinWidth="82">
                                <TextBlock Text="{Binding Dashboard.HealthStatusText}"
                                           Foreground="{Binding Dashboard.HealthStatusBrush}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           TextAlignment="Center"/>
                            </Border>
                        </Grid>

                        <TextBlock Grid.Row="1"
                                   Text="{Binding Dashboard.HealthScoreText}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Margin="0,14,0,12"/>

                        <ProgressBar Grid.Row="2"
                                     Value="{Binding Dashboard.HealthProgressValue}"
                                     Foreground="{Binding Dashboard.HealthStatusBrush}"/>

                        <TextBlock Grid.Row="3"
                                   Text="{Binding Dashboard.HealthSummaryText}"
                                   Style="{StaticResource MutedTextStyle}"
                                   Margin="0,12,0,0"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SmallCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Disk Summary"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding Dashboard.DiskPreviewItems}"
                                      Margin="0,14,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Style="{StaticResource PreviewTextStyle}"
                                               Margin="0,0,0,8"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="CPU History"
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <TextBlock Grid.Column="1"
                                       Text="Live preview"
                                       Foreground="#6F7FA6"
                                       FontSize="12"/>
                        </Grid>

                        <lvc:CartesianChart Grid.Row="1"
                                            Series="{Binding Dashboard.CpuSeries}"
                                            XAxes="{Binding Dashboard.CpuXAxes}"
                                            YAxes="{Binding Dashboard.CpuYAxes}"
                                            DrawMarginFrame="{Binding Dashboard.CpuDrawMarginFrame}"
                                            Background="Transparent"
                                            LegendPosition="Hidden"
                                            TooltipPosition="Hidden"
                                            Margin="0,16,0,0"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Top 3 Processes"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock Grid.Row="1"
                                   Text="Memory-heavy apps right now. Full list lives in Processes."
                                   Style="{StaticResource MutedTextStyle}"
                                   Margin="0,8,0,14"/>

                        <ItemsControl Grid.Row="2"
                                      ItemsSource="{Binding Dashboard.ProcessPreviewItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource PreviewItemStyle}">
                                        <TextBlock Text="{Binding}"
                                                   Style="{StaticResource PreviewTextStyle}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Recent History"
                               Style="{StaticResource SectionTitleStyle}"/>

                    <TextBlock Grid.Row="1"
                               Text="Latest snapshots only. The full history is available on the History page."
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,8,0,14"/>

                    <ItemsControl Grid.Row="2"
                                  ItemsSource="{Binding Dashboard.HistoryPreviewItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#10172A"
                                        CornerRadius="12"
                                        Padding="12,10"
                                        Margin="0,0,12,8">
                                    <TextBlock Text="{Binding}"
                                               Style="{StaticResource PreviewTextStyle}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>