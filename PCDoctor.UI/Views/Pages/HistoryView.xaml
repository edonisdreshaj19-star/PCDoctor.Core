<UserControl x:Class="PCDoctor.UI.Views.Pages.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0B1020"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <Grid Margin="28">
        <Border Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="History"
                           FontSize="28"
                           FontWeight="Bold"/>

                <TextBlock Grid.Row="1"
                           Text="Full recent system-stat history collected from the backend, sorted by newest snapshot."
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,8,0,22"/>

                <Grid Grid.Row="2"
                      Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource SummaryCardStyle}">
                        <StackPanel>
                            <TextBlock Text="ENTRIES"
                                       Style="{StaticResource HeaderTextStyle}"/>

                            <TextBlock Text="{Binding History.HistoryCountText}"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource SummaryCardStyle}">
                        <StackPanel>
                            <TextBlock Text="LATEST SNAPSHOT"
                                       Style="{StaticResource HeaderTextStyle}"/>

                            <TextBlock Text="{Binding History.LatestHistoryTimeText}"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource SummaryCardStyle}">
                        <StackPanel>
                            <TextBlock Text="LATEST CPU / RAM"
                                       Style="{StaticResource HeaderTextStyle}"/>

                            <TextBlock Text="{Binding History.LatestHistoryUsageText}"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3"
                            Style="{StaticResource SummaryCardStyle}"
                            Margin="0">
                        <StackPanel>
                            <TextBlock Text="PRESSURE"
                                       Style="{StaticResource HeaderTextStyle}"/>

                            <TextBlock Text="{Binding History.HistoryAlertText}"
                                       Foreground="{Binding History.HistoryAlertBrush}"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="3"
                      Background="#10172A"
                      MinHeight="42"
                      Margin="0,0,8,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="#"
                               Style="{StaticResource TableHeaderTextStyle}"
                               Margin="14,0,0,0"/>

                    <TextBlock Grid.Column="1"
                               Text="TIME"
                               Style="{StaticResource TableHeaderTextStyle}"/>

                    <TextBlock Grid.Column="2"
                               Text="CPU"
                               Style="{StaticResource TableHeaderTextStyle}"/>

                    <TextBlock Grid.Column="3"
                               Text="CPU USAGE"
                               Style="{StaticResource TableHeaderTextStyle}"/>

                    <TextBlock Grid.Column="4"
                               Text="RAM"
                               Style="{StaticResource TableHeaderTextStyle}"/>

                    <TextBlock Grid.Column="5"
                               Text="RAM USAGE"
                               Style="{StaticResource TableHeaderTextStyle}"/>

                    <TextBlock Grid.Column="6"
                               Text="LEVEL"
                               Style="{StaticResource TableHeaderTextStyle}"/>
                </Grid>

                <ScrollViewer Grid.Row="4"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding History.HistoryRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#10172A"
                                        CornerRadius="12"
                                        Padding="0"
                                        MinHeight="58"
                                        Margin="0,0,8,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="64"/>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="130"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding PositionText}"
                                                   Style="{StaticResource TableCellTextStyle}"
                                                   Foreground="#8F9BB8"
                                                   Margin="14,0,0,0"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding CreatedAtText}"
                                                   Style="{StaticResource TableCellTextStyle}"
                                                   FontWeight="SemiBold"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding CpuUsageText}"
                                                   Style="{StaticResource TableCellTextStyle}"
                                                   Foreground="{Binding CpuUsageBrush}"
                                                   FontWeight="SemiBold"/>

                                        <ProgressBar Grid.Column="3"
                                                     Value="{Binding CpuUsageBarValue, Mode=OneWay}"
                                                     Foreground="{Binding CpuUsageBrush}"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,28,0"/>

                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding MemoryUsageText}"
                                                   Style="{StaticResource TableCellTextStyle}"
                                                   Foreground="{Binding MemoryUsageBrush}"
                                                   FontWeight="SemiBold"/>

                                        <ProgressBar Grid.Column="5"
                                                     Value="{Binding MemoryUsageBarValue, Mode=OneWay}"
                                                     Foreground="{Binding MemoryUsageBrush}"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,28,0"/>

                                        <Border Grid.Column="6"
                                                Background="#222B45"
                                                CornerRadius="10"
                                                Padding="10,5"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding LevelText}"
                                                       Foreground="{Binding LevelBrush}"
                                                       FontSize="12"
                                                       FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>