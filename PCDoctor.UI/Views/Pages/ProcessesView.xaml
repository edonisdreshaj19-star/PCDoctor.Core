<UserControl x:Class="PCDoctor.UI.Views.Pages.ProcessesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0B1020"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <Grid Margin="28">
        <Border Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Processes"
                           FontSize="28"
                           FontWeight="Bold"/>

                <TextBlock Grid.Row="1"
                           Text="Full list of memory-heavy processes reported by the monitoring service, sorted by highest memory usage."
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,8,0,22"/>

                <Grid Grid.Row="2"
                      Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource SummaryCardStyle}">
                        <StackPanel>
                            <TextBlock Text="MONITORED"
                                       Style="{StaticResource HeaderTextStyle}"/>

                            <TextBlock Text="{Binding Processes.ProcessCountText}"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource SummaryCardStyle}">
                        <StackPanel>
                            <TextBlock Text="HEAVIEST PROCESS"
                                       Style="{StaticResource HeaderTextStyle}"/>

                            <TextBlock Text="{Binding Processes.HeaviestProcessText}"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource SummaryCardStyle}"
                            Margin="0">
                        <StackPanel>
                            <TextBlock Text="MEMORY PRESSURE"
                                       Style="{StaticResource HeaderTextStyle}"/>

                            <TextBlock Text="{Binding Processes.ProcessAlertText}"
                                       Foreground="{Binding Processes.ProcessAlertBrush}"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="3"
                      Background="#10172A"
                      MinHeight="42"
                      Margin="0,0,8,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="54"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="#"
                               Style="{StaticResource TableHeaderTextStyle}"
                               Margin="14,0,0,0"/>

                    <TextBlock Grid.Column="1"
                               Text="PROCESS"
                               Style="{StaticResource TableHeaderTextStyle}"/>

                    <TextBlock Grid.Column="2"
                               Text="PID"
                               Style="{StaticResource TableHeaderTextStyle}"/>

                    <TextBlock Grid.Column="3"
                               Text="MEMORY"
                               Style="{StaticResource TableHeaderTextStyle}"/>

                    <TextBlock Grid.Column="4"
                               Text="LEVEL"
                               Style="{StaticResource TableHeaderTextStyle}"/>

                    <TextBlock Grid.Column="5"
                               Text="USAGE"
                               Style="{StaticResource TableHeaderTextStyle}"/>
                </Grid>

                <ScrollViewer Grid.Row="4"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Processes.ProcessRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#10172A"
                                        CornerRadius="12"
                                        Padding="0"
                                        MinHeight="58"
                                        Margin="0,0,8,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="54"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="180"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding PositionText}"
                                                   Style="{StaticResource TableCellTextStyle}"
                                                   Foreground="#8F9BB8"
                                                   Margin="14,0,0,0"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ProcessName}"
                                                   Style="{StaticResource TableCellTextStyle}"
                                                   FontWeight="SemiBold"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding ProcessId}"
                                                   Style="{StaticResource TableCellTextStyle}"
                                                   Foreground="#A9B7D8"/>

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding MemoryUsageText}"
                                                   Style="{StaticResource TableCellTextStyle}"
                                                   FontWeight="SemiBold"/>

                                        <Border Grid.Column="4"
                                                Background="#222B45"
                                                CornerRadius="10"
                                                Padding="10,5"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding MemoryLevelText}"
                                                       Foreground="{Binding MemoryUsageBrush}"
                                                       FontSize="12"
                                                       FontWeight="Bold"/>
                                        </Border>

                                        <ProgressBar Grid.Column="5"
                                                     Value="{Binding MemoryUsageBarValue, Mode=OneWay}"
                                                     Foreground="{Binding MemoryUsageBrush}"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,18,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>