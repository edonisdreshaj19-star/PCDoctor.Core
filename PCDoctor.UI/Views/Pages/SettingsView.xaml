<UserControl x:Class="PCDoctor.UI.Views.Pages.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0B1020"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <Style x:Key="SettingsTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#10172A"/>
            <Setter Property="Foreground" Value="#EAF0FF"/>
            <Setter Property="BorderBrush" Value="#29324A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#334166"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="42"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#182139"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#4A1F2A"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="22"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="22"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Application Settings"
                                   FontSize="26"
                                   FontWeight="Bold"/>

                        <TextBlock Text="Configure API connection, refresh behavior, and local device registration."
                                   Style="{StaticResource MutedTextStyle}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource SummaryCardStyle}">
                            <StackPanel>
                                <TextBlock Text="API STATUS"
                                           Style="{StaticResource HeaderTextStyle}"/>

                                <TextBlock Text="{Binding Settings.ApiStatusText}"
                                           Foreground="{Binding Settings.ApiStatusBrush}"
                                           Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Style="{StaticResource SummaryCardStyle}">
                            <StackPanel>
                                <TextBlock Text="LAST SUCCESSFUL SYNC"
                                           Style="{StaticResource HeaderTextStyle}"/>

                                <TextBlock Text="{Binding Settings.LastSuccessfulSyncText}"
                                           Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource SummaryCardStyle}"
                                Margin="0">
                            <StackPanel>
                                <TextBlock Text="DEVICE"
                                           Style="{StaticResource HeaderTextStyle}"/>

                                <TextBlock Text="{Binding Settings.DeviceNameText}"
                                           Style="{StaticResource ValueTextStyle}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*"/>
                    <ColumnDefinition Width="0.65*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="API Configuration"
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <TextBlock Text="These values are saved locally and used by the monitoring service."
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,8,0,0"/>
                        </StackPanel>

                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="3">
                                <TextBlock Text="API Base URL"
                                           Style="{StaticResource HeaderTextStyle}"
                                           Margin="0,0,0,7"/>

                                <TextBox Text="{Binding Settings.ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SettingsTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2"
                                        Grid.Column="0">
                                <TextBlock Text="Refresh Interval"
                                           Style="{StaticResource HeaderTextStyle}"
                                           Margin="0,0,0,7"/>

                                <TextBox Text="{Binding Settings.RefreshIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SettingsTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2"
                                        Grid.Column="2">
                                <TextBlock Text="Seconds"
                                           Style="{StaticResource HeaderTextStyle}"
                                           Margin="0,0,0,7"/>

                                <TextBlock Text="How often the UI refreshes."
                                           Style="{StaticResource MutedTextStyle}"
                                           VerticalAlignment="Center"
                                           Margin="0,9,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="4"
                                        Grid.Column="0">
                                <TextBlock Text="API Upload Interval"
                                           Style="{StaticResource HeaderTextStyle}"
                                           Margin="0,0,0,7"/>

                                <TextBox Text="{Binding Settings.ApiSendIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SettingsTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="4"
                                        Grid.Column="2">
                                <TextBlock Text="Seconds"
                                           Style="{StaticResource HeaderTextStyle}"
                                           Margin="0,0,0,7"/>

                                <TextBlock Text="How often stats are sent to the backend."
                                           Style="{StaticResource MutedTextStyle}"
                                           VerticalAlignment="Center"
                                           Margin="0,9,0,0"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Grid.Row="4"
                                   Text="{Binding Settings.StatusMessage}"
                                   Foreground="{Binding Settings.StatusBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Current Device"
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <TextBlock Text="Local registration used for authenticated API communication."
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,8,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="DEVICE NAME"
                                       Style="{StaticResource HeaderTextStyle}"/>

                            <TextBlock Text="{Binding Settings.DeviceNameText}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Margin="0,7,0,16"/>

                            <TextBlock Text="DEVICE ID"
                                       Style="{StaticResource HeaderTextStyle}"/>

                            <TextBlock Text="{Binding Settings.DeviceIdText}"
                                       Foreground="#D7DEF5"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       Margin="0,7,0,16"/>

                            <TextBlock Text="OPERATING SYSTEM"
                                       Style="{StaticResource HeaderTextStyle}"/>

                            <TextBlock Text="{Binding Settings.OperatingSystemText}"
                                       Foreground="#D7DEF5"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       Margin="0,7,0,0"/>
                        </StackPanel>

                        <TextBlock Grid.Row="4"
                                   Text="Resetting the device registration deletes the stored local device token. PCDoctor will register as a new device on the next successful sync."
                                   Style="{StaticResource MutedTextStyle}"/>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="4"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                VerticalAlignment="Center">
                        <TextBlock Text="Save changes"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock Text="Changes are applied immediately after saving."
                                   Style="{StaticResource MutedTextStyle}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Load Defaults"
                            Command="{Binding Settings.ResetToDefaultsCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="145"
                            VerticalAlignment="Center"/>

                    <Button Grid.Column="3"
                            Content="Reset Device"
                            Command="{Binding Settings.ResetDeviceRegistrationCommand}"
                            Style="{StaticResource DangerButtonStyle}"
                            MinWidth="145"
                            VerticalAlignment="Center"/>

                    <Button Grid.Column="5"
                            Content="Save"
                            Command="{Binding Settings.SaveCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            MinWidth="145"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>